{
  "name": "@uplift-ltd/nexus",
  "type": "module",
  "version": "4.1.2",
  "description": "nexus",
  "license": "MIT",
  "author": "Uplift Agency Ltd. <npm@uplift.ltd>",
  "main": "./cjs/nexus.cjs",
  "module": "./esm/nexus.js",
  "types": "./esm/nexus.d.ts",
  "exports": {
    ".": {
      "types": "./esm/nexus.d.ts",
      "import": "./esm/nexus.js",
      "require": "./cjs/nexus.cjs"
    }
  },
  "bin": {
    "nexus": "./cjs/nexus.cjs"
  },
  "files": [
    "cjs/",
    "esm/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uplift-ltd/nexus.git",
    "directory": "packages/nexus"
  },
  "bugs": {
    "url": "https://github.com/uplift-ltd/nexus/issues?q=is:open+is:issue+label:nexus"
  },
  "homepage": "https://nexus.uplift.ltd/docs/packages/nexus",
  "scripts": {
    "clean": "git clean -dfx cjs esm",
    "build": "run-s clean build:cjs build:cjs-rename build:esm build:version",
    "build:esm": "tsc --outDir ./esm --module es2020",
    "build:cjs": "tsc --outDir ./cjs --module commonjs",
    "build:cjs-rename": "node ./esm/renameCjsExtensions.js ./cjs",
    "build:version": "node ./esm/nexus.js replace-program-version",
    "version": "npm run build:version && git add cjs esm",
    "check-types": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "read-package-up": "^12.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "replace-in-file": "^8.4.0"
  }
}
